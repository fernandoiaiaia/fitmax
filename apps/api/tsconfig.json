{
  "compilerOptions": {
    "target": "es2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@config/*": ["./src/config/*"],
      "@lib/*": ["./src/lib/*"],
      "@middlewares/*": ["./src/middlewares/*"],
      "@modules/*": ["./src/modules/*"],
      "@jobs/*": ["./src/jobs/*"],
      "@routes/*": ["./src/routes/*"],
      "@types/*": ["./src/types/*"]
    }
  },
  "include": ["src/**/*"]
}
