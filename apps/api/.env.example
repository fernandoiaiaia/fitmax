# Environment Variables — FitMax API
# Copy this file to .env and fill in your values.

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fitmax"

# ─── Cache & Queues (Redis) ────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Authentication ────────────────────────────────────────────────────────
# Must be at least 32 characters long
JWT_SECRET="change-me-to-a-secure-random-string-minimum-32-chars"
JWT_EXPIRES_IN="7d"
