{
  "name": "fitmax-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:contract": "npm run test:contract:generate --workspace=web-admin && npm run test:contract:verify --workspace=api",
    "test:contract:pro": "npm run test:contract:generate --workspace=web-pro && npm run test:contract:verify:pro --workspace=api",
    "test:contract:client": "npm run test:contract:generate --workspace=web-client && node apps/api/src/verify-contract-client.js",
    "test:visual:pro": "npm run test:visual --workspace=web-pro",
    "test:visual:client": "npm run test:visual --workspace=web-client",
    "test:a11y:pro": "npm run test:a11y --workspace=web-pro",
    "test:a11y:client": "npm run test:a11y --workspace=web-client",
    "test:recovery": "npm run test:recovery --workspace=api",
    "test:mutation": "npm run test:mutation --workspace=web-admin",
    "test:mutation:pro": "npm run test:mutation --workspace=web-pro",
    "test:mutation:client": "npm run test:mutation --workspace=web-client",
    "test:mutation:backend": "npm run test:mutation:backend --workspace=api",
    "test:mutation:pro:backend": "node apps/api/src/modules/pro/dashboard/__tests__/mutation.js",
    "test:mutation:client:backend": "node apps/api/src/modules/client-portal/dashboard/__tests__/mutation.js",
    "test:integration:pro:backend": "node apps/api/src/pro-backend-e2e.js",
    "test:integration:client:backend": "node apps/api/src/client-backend-e2e.js",
    "test:scalability:pro:backend": "node apps/api/src/pro-backend-scalability.js",
    "test:scalability:client:backend": "node apps/api/src/client-backend-scalability.js",
    "test:recovery:pro:backend": "node apps/api/src/pro-backend-recovery.js",
    "test:recovery:client:backend": "node apps/api/src/client-backend-recovery.js",
    "test:security:client:backend": "node apps/api/src/client-backend-security.js"
  },
  "devDependencies": {
    "@types/react-native": "^0.72.8",
    "turbo": "latest"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.8.1",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@types/pg": "^8.20.0",
    "pg": "^8.21.0"
  }
}
